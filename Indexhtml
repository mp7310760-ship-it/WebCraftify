package com.linguabookhub.controller;

import org.springframework.web.bind.annotation.; import java.io.; import java.net.*;

@RestController @RequestMapping("/api") @CrossOrigin public class TranslateController {

@GetMapping("/translate")
public String translate(@RequestParam String text) {
    try {
        String urlStr = "https://api.mymemory.translated.net/get?q="
                + URLEncoder.encode(text, "UTF-8")
                + "&langpair=hi|en";

        URL url = new URL(urlStr);
        BufferedReader br = new BufferedReader(
                new InputStreamReader(url.openStream()));

        String output;
        StringBuilder result = new StringBuilder();

        while ((output = br.readLine()) != null) {
            result.append(output);
        }

        return result.toString();

    } catch (Exception e) {
        return "Error: " + e.getMessage();
    }
}
}

